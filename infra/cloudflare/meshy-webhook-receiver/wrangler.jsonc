{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "3dprintyou-meshy-webhook",
  "main": "src/index.js",
  "compatibility_date": "2026-05-23",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "api.3dprintyou.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "ENVIRONMENT": "staging"
  }
}
