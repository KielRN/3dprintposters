rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasAccount() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function isAdmin() {
      return hasAccount()
        && (request.auth.token.admin == true
          || request.auth.token.role == "admin");
    }

    function underUserPath(uid) {
      return hasAccount() && request.auth.uid == uid;
    }

    match /uploads/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if underUserPath(uid)
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /generated/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if false;
    }

    match /admin/workflow-style-references/{styleId}/{fileName} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png)');
    }

    match /print-files/{uid}/{jobId}/{allPaths=**} {
      allow read: if underUserPath(uid);
      allow write: if false;
    }

    match /stl/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
