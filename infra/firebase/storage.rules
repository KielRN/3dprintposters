rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function underUserPath(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /uploads/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if underUserPath(uid)
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /generated/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if false;
    }

    match /stl/{uid}/{jobId}/{fileName} {
      allow read: if underUserPath(uid);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
