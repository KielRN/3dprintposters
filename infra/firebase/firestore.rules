rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function ownsNewDoc() {
      return signedIn() && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if ownsExistingDoc();
      allow create: if ownsNewDoc()
        && request.resource.data.status == "created";
      allow update, delete: if false;
    }

    match /orders/{orderId} {
      allow read: if ownsExistingDoc();
      allow create, update, delete: if false;
    }

    match /fulfillmentEvents/{eventId} {
      allow read: if signedIn()
        && exists(/databases/$(database)/documents/orders/$(resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

