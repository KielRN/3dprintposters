{
  "name": "3d-print-posters",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first web app for AI-generated 3D printable poster orders.",
  "workspaces": [
    "apps/web",
    "apps/functions"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "stripe:create-poster-product": "node scripts/stripe/create-poster-product.mjs",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^6.0.3"
  }
}
