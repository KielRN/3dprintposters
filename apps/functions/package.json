{
  "name": "@3d-print-posters/functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && node ../../scripts/firebase/check-emulator-java.mjs && firebase emulators:start --only auth,functions,firestore,storage --project dev",
    "serve:functions": "npm run build && firebase emulators:start --only functions --project dev",
    "deploy": "firebase deploy --only functions",
    "test:admin-support": "npm run build && node --test test/adminSupport.test.mjs",
    "test:job-cost": "npm run build && node --test test/jobCost.test.mjs",
    "test:workflow-config": "npm run build && node --test test/figurineWorkflowConfig.test.mjs test/aiProviderReferenceImages.test.mjs test/meshyFigurineProvider.test.mjs",
    "test:pipeline": "npm run build && node --test test/pipeline.test.mjs test/operatorConsole.test.mjs",
    "typecheck": "tsc --noEmit",
    "seed:dev-paid-order": "node scripts/seed-dev-paid-order.mjs",
    "seed:chibi-female-workflow": "node scripts/seed-chibi-female-workflow.mjs",
    "seed:chibi-female-workflow:dry-run": "node scripts/seed-chibi-female-workflow.mjs --dry-run",
    "seed:heroic-workflow": "node scripts/seed-heroic-workflow.mjs",
    "seed:heroic-female-workflow": "node scripts/seed-heroic-female-workflow.mjs",
    "seed:superhero-female-workflow": "node scripts/seed-superhero-female-workflow.mjs",
    "seed:superhero-female-workflow:dry-run": "node scripts/seed-superhero-female-workflow.mjs --dry-run",
    "seed:chibi-photo-workflows": "node scripts/seed-chibi-photo-workflows.mjs",
    "seed:chibi-photo-workflows:dry-run": "node scripts/seed-chibi-photo-workflows.mjs --dry-run"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "typescript": "^6.0.3"
  }
}
